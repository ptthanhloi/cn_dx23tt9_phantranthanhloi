# Sao chep file nay thanh `.env` va dien gia tri thuc te.
# File `.env` KHONG duoc commit len git.

# Khoa bi mat Django (sinh moi bang: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
DJANGO_SECRET_KEY=thay-bang-secret-key-cua-ban

# Bat/tat che do debug (True khi phat trien, False khi production)
DJANGO_DEBUG=True

# Host duoc phep truy cap, cach nhau bang dau phay. Vi du: localhost,127.0.0.1,example.com
DJANGO_ALLOWED_HOSTS=*
